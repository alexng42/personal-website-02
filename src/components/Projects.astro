---
const projects = [
  {
    name: 'UBC Course Planner',
    description: 'Responsive GUI course planning application built with .NET MAUI using MVVM architecture. Features schedule saving and course conflict prevention.',
    language: 'C#',
    tags: ['C#', '.NET MAUI'],
    year: '2025',
    org: 'University of British Columbia',
    url: 'https://github.com/alexng42',
  },
  {
    name: 'Stacker Game',
    description: 'Recreation of the classic Stacker arcade game in C using the SDL3 framework, implementing block movement, collision detection, and grid logic.',
    language: 'C',
    tags: ['C', 'SDL3'],
    year: '2025',
    org: 'Personal Project',
    url: 'https://github.com/alexng42',
  },
  {
    name: 'Tron Game',
    description: 'Real-time light-cycle Tron game for an Intel DE10-Lite FPGA in C with RISC-V. Uses interrupt service routines for input and detects collisions via VGA frame buffer pixel data.',
    language: 'C',
    tags: ['C', 'RISC-V', 'FPGA'],
    year: '2025',
    org: 'University of British Columbia',
    url: 'https://github.com/alexng42',
  },
  {
    name: 'Personal Website',
    description: 'Professional responsive portfolio website built with HTML and CSS, deployed to GitHub Pages with cross-browser and mobile compatibility.',
    language: 'HTML',
    tags: ['HTML', 'CSS'],
    year: '2025',
    org: 'alexng42.github.io',
    url: 'https://alexng42.github.io',
  },
  {
    name: 'Line Following Robot',
    description: 'Led a team of three to design and program a Pololu 3pi robot using PID control in C to complete eight obstacle challenges, with sensor and motor calibration for competition day.',
    language: 'C',
    tags: ['C', 'PID Control'],
    year: '2025',
    org: 'Kwantlen Polytechnic University',
    url: 'https://github.com/alexng42',
  },
  {
    name: 'Hardware-Based Safe Combination Lock',
    description: 'Complex FSM in SystemVerilog for a secure safe system across DE10-Lite and DE1-SoC FPGAs with a 4×4 keypad, resolving metastability and switch bounce via debouncing and synchronizer flip-flops.',
    language: 'SystemVerilog',
    tags: ['RISC-V', 'FPGA', 'SystemVerilog'],
    year: '2025',
    org: 'University of British Columbia',
    url: 'https://github.com/alexng42',
  },
  {
    name: '8-Bit Simple CPU',
    description: 'Custom 8-bit CPU in SystemVerilog featuring an ALU (add, sub, mul, AND) with condition flags, dual-ported register file, 128-location memory, and memory-mapped I/O for HEX displays.',
    language: 'SystemVerilog',
    tags: ['RISC-V', 'FPGA', 'SystemVerilog'],
    year: '2025',
    org: 'University of British Columbia',
    url: 'https://github.com/alexng42',
  },
];
 
const langColors: Record<string, string> = {
  'C#': 'bg-purple-500',
  'C': 'bg-blue-500',
  'HTML': 'bg-orange-500',
  'SystemVerilog': 'bg-emerald-500',
  'Java': 'bg-red-500',
};
---
 
<section id="projects" class="py-6 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="bash-prompt animate"><span class="prompt-symbol">~</span> <span class="prompt-dollar">$</span> ls ~/projects</div>
    <h2 class="section-title animate">Projects</h2>
 
    <div class="grid gap-4 sm:grid-cols-2">
      {projects.map((project, i) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`animate stagger-${Math.min(i + 1, 4)} group block rounded-2xl border border-stone-200/60 dark:border-stone-800/60 bg-white dark:bg-stone-900/60 p-5 card-hover`}
        >
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
              </svg>
              <h3 class="text-sm font-semibold text-stone-900 dark:text-stone-50 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors duration-300">
                {project.name}
              </h3>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-stone-400 dark:text-stone-500 font-mono">{project.year}</span>
              <svg class="w-4 h-4 text-stone-300 dark:text-stone-600 group-hover:text-stone-500 dark:group-hover:text-stone-400 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </div>
          </div>
 
          <p class="text-xs text-stone-400 dark:text-stone-500 mb-2 flex items-center gap-1">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 0115 0z" />
            </svg>
            {project.org}
          </p>
 
          <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed mb-3">
            {project.description}
          </p>
 
          <div class="flex items-center gap-2 flex-wrap">
            {project.tags.map((tag) => (
              <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[11px] font-semibold border bg-stone-100/80 text-stone-600 dark:bg-stone-500/10 dark:text-stone-300 border-stone-200/50 dark:border-stone-500/20">
                <span class={`w-1.5 h-1.5 rounded-full ${langColors[tag] || langColors[project.language] || 'bg-stone-400'}`}></span>
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>