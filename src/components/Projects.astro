---
const projects = [
  {
    name: 'discord-llm',
    description: 'A Discord bot powered by LLMs for conversational AI directly in Discord servers.',
    language: 'Python',
    url: 'https://github.com/doIIarplus/discord-llm',
    stars: 1,
  },
  {
    name: 'discord_game_bot',
    description: 'Bot to manage locally hosted multiplayer game servers, handling spin-up, status, and player coordination through Discord.',
    language: 'Python',
    url: 'https://github.com/doIIarplus/discord_game_bot',
    stars: 0,
  },
  {
    name: 'Disclipy',
    description: 'A command-line interface for Discord built in Python 3, enabling chat and server interaction from the terminal.',
    language: 'Python',
    url: 'https://github.com/doIIarplus/Disclipy',
    stars: 2,
  },
  {
    name: 'osu-replayer',
    description: 'Plays back osu! replay files (.osr), rendering cursor movement and hit interactions from recorded gameplay.',
    language: 'Java',
    url: 'https://github.com/doIIarplus/osu-replayer',
    stars: 0,
  },
  {
    name: 'Neural-Network',
    description: 'A from-scratch Java implementation of artificial neural networks, based on AI-Junkie\'s ANN blog series.',
    language: 'Java',
    url: 'https://github.com/doIIarplus/Neural-Network',
    stars: 0,
  },
];

const langColors: Record<string, string> = {
  'Python': 'bg-blue-400',
  'Java': 'bg-orange-400',
};
---

<section id="projects" class="py-6 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="section-title animate">Projects</h2>

    <div class="grid gap-4 sm:grid-cols-2">
      {projects.map((project, i) => (
        <a
          href={project.url}
          target="_blank"
          rel="noopener noreferrer"
          class={`animate stagger-${Math.min(i + 1, 4)} group block rounded-2xl border border-stone-200/60 dark:border-stone-800/60 bg-white dark:bg-stone-900/60 p-5 card-hover`}
        >
          <div class="flex items-center justify-between mb-2">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-stone-400 dark:text-stone-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />
              </svg>
              <h3 class="text-sm font-semibold text-stone-900 dark:text-stone-50 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors duration-300">
                {project.name}
              </h3>
            </div>
            <svg class="w-4 h-4 text-stone-300 dark:text-stone-600 group-hover:text-stone-500 dark:group-hover:text-stone-400 transition-all duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>

          <p class="text-sm text-stone-500 dark:text-stone-400 leading-relaxed mb-3">
            {project.description}
          </p>

          <div class="flex items-center gap-3 text-xs text-stone-400 dark:text-stone-500">
            <span class="flex items-center gap-1.5">
              <span class={`w-2.5 h-2.5 rounded-full ${langColors[project.language] || 'bg-stone-400'}`}></span>
              {project.language}
            </span>
            {project.stars > 0 && (
              <span class="flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                </svg>
                {project.stars}
              </span>
            )}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
