---
---

<section class="relative flex items-center pt-24 pb-4 px-6 overflow-hidden">
  <!-- Subtle gradient orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-gradient-to-br from-indigo-200/30 to-purple-200/30 dark:from-indigo-900/15 dark:to-purple-900/15 rounded-full blur-3xl animate-float"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-gradient-to-tr from-pink-200/20 to-orange-200/20 dark:from-pink-900/10 dark:to-orange-900/10 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
  </div>

  <!-- Grid pattern -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#8882_1px,transparent_1px),linear-gradient(to_bottom,#8882_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_50%_50%_at_50%_50%,#000_60%,transparent_100%)] pointer-events-none opacity-[0.12] dark:opacity-[0.05]"></div>

  <div class="relative max-w-5xl mx-auto w-full">
    <div class="max-w-2xl">
      <!-- Terminal-style greeting -->
      <div class="animate stagger-1 font-mono text-sm text-stone-400 dark:text-stone-500 mb-3">
        <span class="text-emerald-600 dark:text-emerald-400">~</span> <span class="text-stone-500 dark:text-stone-400">$</span> whoami
      </div>

      <h1 class="animate stagger-2 font-mono">
        <span class="text-stone-500 dark:text-stone-400 text-lg">Hi, I'm </span>
        <span class="block text-4xl sm:text-5xl font-bold tracking-tight text-stone-900 dark:text-stone-50 leading-[1.1] mt-1">
          Jasper Shan<span class="inline-block w-[3px] h-[0.9em] bg-stone-900 dark:bg-stone-50 ml-1 align-middle animate-blink"></span>
        </span>
      </h1>

      <p class="animate stagger-3 mt-5 text-base font-mono text-stone-500 dark:text-stone-400 leading-relaxed">
        I'm an ML infrastructure & training systems engineer at
        <span class="font-semibold text-stone-800 dark:text-stone-200">Meta</span>.
        I build training optimizations for recommendation models — embedding pruning,
        offloading, and model freshness — using PyTorch, TorchRec, and FBGEMM.
      </p>

      <div class="animate stagger-4 mt-7 flex flex-wrap gap-3">
        <a
          href="mailto:jaspershan@gmail.com"
          class="group inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-stone-900 dark:bg-stone-100 text-white dark:text-stone-900 text-sm font-mono font-semibold hover:bg-stone-700 dark:hover:bg-stone-300 transition-all duration-300 hover:-translate-y-0.5"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
          Get in touch
        </a>
        <a
          href="/resume.pdf"
          target="_blank"
          class="group inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-stone-200 dark:border-stone-700 text-sm font-mono font-semibold hover:bg-stone-100 dark:hover:bg-stone-800 transition-all duration-300 hover:-translate-y-0.5"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Resume
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink {
    animation: blink 1s step-end infinite;
  }
</style>
